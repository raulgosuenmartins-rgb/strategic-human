# ── Google Gemini AI ─────────────────────────────────────────────────────────
# Required for AI features. Configure via Secrets panel no AI Studio.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ── App URL ───────────────────────────────────────────────────────────────────
# URL pública do portal. Usado para CORS e links auto-referenciais.
# AI Studio injeta automaticamente o Cloud Run service URL em produção.
APP_URL="http://localhost:3000"

# ── Servidor Express (API) ────────────────────────────────────────────────────
# Porta do servidor Express. Frontend faz proxy /api/* para esta porta.
PORT=3001

# ── Notificações de Leads ─────────────────────────────────────────────────────
# E-mail para receber notificações de novos leads do formulário de contato.
NOTIFICATION_EMAIL="advisor@strategichuman.com"

# ── Configuração SMTP ─────────────────────────────────────────────────────────
# Usada por execution/send_notification.py para envio de e-mails.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
